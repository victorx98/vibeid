# Copy this file to .env and fill in the values before running the server.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# Comma-separated list of extra allowed CORS origins. chrome-extension://* and
# localhost are always allowed; add your hosted origins here if needed.
# ALLOWED_ORIGINS=https://app.example.com

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy fallback: only used when SUPABASE_SECRET_KEY is missing.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ── Google OAuth (extension) ──────────────────────────────────────────────────
# Required for hosted auth emails. Also used as the default signup confirmation
# redirect when POST /auth/signup omits redirectTo.
# Local: http://127.0.0.1:3000/auth/recovery
# Production: https://vibeid.co/auth/recovery
# AUTH_ALLOWED_REDIRECT_PREFIX=https://vibeid.co/auth/recovery

# Local Supabase CLI only — read by supabase/config.toml [auth.external.google]:
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# ── Stripe / Billing ──────────────────────────────────────────────────────────
BILLING_ENABLED=false
BILLING_KILL_SWITCH=false

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_PREMIUM=price_...
# CHECKOUT_SUCCESS_URL=https://app.example.com/checkout/success
# CHECKOUT_CANCEL_URL=https://app.example.com/checkout/cancel
# Optional fallback when POST /billing/checkout omits extensionId (from chrome.runtime.id).
# EXTENSION_ID=your32characterextensionid
# GET /checkout/success and GET /checkout/cancel serve bridge pages that redirect
# to chrome-extension://…/purchase/success.html or purchase/purchase.html.
# ENTITLEMENTS_SECRET=
