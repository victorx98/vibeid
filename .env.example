# Copy this file to .env and fill in the values before running the app.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.

# ── AI ──────────────────────────────────────────────────────────────────────
# Required. Obtain from console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable (anon) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-side admin key. Prefer this over the legacy service-role key.
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy fallback: only used when SUPABASE_SECRET_KEY is missing.
# Prefer SUPABASE_SECRET_KEY for all new deployments.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PostgreSQL connection string. Find the password in Supabase → Project Settings → Database.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Stripe ───────────────────────────────────────────────────────────────────
# Secret key — server-side only. Required when BILLING_ENABLED=true.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from the Stripe dashboard → Webhooks. Required when BILLING_ENABLED=true.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products in the Stripe dashboard and paste the price IDs here.
# Required when BILLING_ENABLED=true.
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_RESUME=price_...

# Publishable key — needed if/when Stripe Elements (client-side payment UI) is added.
# Currently unused: the checkout flow goes server-side only via Stripe Checkout Sessions.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── WeChat Pay ───────────────────────────────────────────────────────────────
# Official WeChat Pay API v3 direct integration. Requires BILLING_ENABLED=true.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_APP_SECRET=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=

# Provide either inline PEM text with \n escapes, or a filesystem path.
WECHAT_PAY_PRIVATE_KEY=
# WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat-pay-private-key.pem
WECHAT_PAY_PUBLIC_KEY=
# WECHAT_PAY_PUBLIC_KEY_PATH=/run/secrets/wechat-pay-public-key.pem

# Server-owned prices in CNY cents.
WECHAT_PRICE_BASIC_CNY_CENTS=3900
WECHAT_PRICE_RESUME_CNY_CENTS=9900

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Master switch for billing. When false, checkout and entitlement routes are no-ops.
BILLING_ENABLED=false

# Emergency kill switch. Overrides BILLING_ENABLED and blocks all checkout traffic immediately.
BILLING_KILL_SWITCH=false

# Secret used to sign entitlement tokens. Must be at least 32 characters.
# Required when BILLING_ENABLED=true. Generate with: openssl rand -hex 32
ENTITLEMENTS_SECRET=

# Enable the demo unlock flow (creates unlocks without payment). Off by default.
NEXT_PUBLIC_DEMO_UNLOCKS_ENABLED=false

# Serve the static Vibe ID sample embed at /vibe-id-sample. Off by default.
NEXT_PUBLIC_ENABLE_VIBE_SAMPLE=false

# ── Migration Script Only ─────────────────────────────────────────────────────
# Path to the legacy SQLite knowledge-base file used by scripts/migrate-sqlite-kb.ts.
# Only needed for the one-time migration; the app itself uses Postgres.
# Defaults to data/resume_material_library.db if not set.
# SQLITE_KB_PATH=data/resume_material_library.db
